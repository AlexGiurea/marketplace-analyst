# Copy to .env (never commit .env). Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4
PORT=5173

# --- Chat abuse protection (optional; defaults are safe for small public demos) ---
# Set to 1 only for local debugging if you need to bypass limits.
# CHAT_RATE_LIMIT_DISABLE=0
# Sliding window: max requests per IP per window (default 60s, max 20).
# CHAT_RATE_LIMIT_WINDOW_MS=60000
# CHAT_RATE_LIMIT_MAX=20
# Second ceiling: max requests per IP per rolling hour (default 150).
# CHAT_RATE_LIMIT_HOUR_MAX=150
# Max JSON body size in bytes for POST /api/chat (default 524288 = 512 KiB).
# CHAT_MAX_REQUEST_BYTES=524288
# Max messages in history array (default 36).
# CHAT_MAX_MESSAGES=36
# Max characters per message content string (default 12000).
# CHAT_MAX_MESSAGE_CHARS=12000
