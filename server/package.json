{
  "name": "marketplace-analyst-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude ../frontend/node_modules --exclude ../frontend/dist src/index.ts",
    "start": "cross-env NODE_ENV=production tsx src/index.ts",
    "build": "npm run build --prefix ../frontend",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "vite": "^6.3.4",
    "vitest": "^3.0.5"
  }
}
